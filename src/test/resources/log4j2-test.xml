<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="warn" name="test">
    <Appenders>
        <Console name="STDOUT" target="SYSTEM_OUT" follow="true">
            <PatternLayout pattern="%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX} %-5level [%15.15t] %logger{36} - %msg%replace{%replace{%mdc}{^\{\}$}{}}{^(.+)$}{ $1}%n%n"/>
        </Console>
    </Appenders>
    <Loggers>
        <Root level="info">
            <AppenderRef ref="STDOUT"/>
        </Root>
    </Loggers>
</Configuration>
